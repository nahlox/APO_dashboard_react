# ──────────────────────────────────────────────────────────────
# Exemple de .env pour un client utilisant Sage + SQL Server
# Copier en .env et remplir les valeurs réelles du client
# ──────────────────────────────────────────────────────────────

# Supabase (commun à tous les tenants)
SUPABASE_URL=https://iwfgvhenqzdutjcxhuip.supabase.co
SUPABASE_KEY=eyJ...                        # service_role key (pas anon)

# SQL Server — Sage du client
SAGE_SERVER=192.168.1.10\SQLEXPRESS        # IP ou hostname + instance
# SAGE_SERVER=192.168.1.10,1433            # alternative avec port explicite
SAGE_DATABASE=COMPTA_HUILERIE_2026         # nom exact de la base Sage
SAGE_USER=sa                               # compte SQL Server (lecture seule recommandé)
SAGE_PASSWORD=MotDePasseClient123

# Optionnel : si Sage est accessible via VPN ou tunnel SSH
# SAGE_SERVER=localhost,1433               # après tunnel SSH : ssh -L 1433:srv_sage:1433 user@vpn
