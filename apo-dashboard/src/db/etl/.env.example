SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...

# ── Dropbox — Mode PERMANENT (recommandé) ─────────────────────
# Récupère App Key + App Secret sur https://www.dropbox.com/developers/apps
# Lance python3 get_dropbox_token.py UNE SEULE FOIS pour obtenir le refresh token
DROPBOX_APP_KEY=xxxxxxxxxxxxxxx
DROPBOX_APP_SECRET=xxxxxxxxxxxxxxx
DROPBOX_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Dropbox — Mode temporaire (expire en quelques heures) ─────
# Généré sur la console Dropbox → Settings → "Generated access token"
# Inutile si les 3 variables ci-dessus sont renseignées
# DROPBOX_TOKEN=sl.xxx...
